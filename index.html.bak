<!-- Diary Modal -->
<div class="modal-overlay" id="diaryModal" onclick="if(event.target===this)closeDiary()">
<div class="modal-content">
<button class="modal-close" onclick="closeDiary()">✕</button>
<button class="share-float" id="shareBtn" onclick="shareDiary()">📋 分享</button>
<div id="diaryModalBody"></div>
<div style="display:flex;justify-content:space-between;align-items:center;margin-top:16px;padding-top:12px;border-top:2px dashed #ddd"><button onclick="prevDiary()" id="btnPrev" class="btn-outline" style="font-size:13px;padding:6px 14px">← 上一篇</button><span id="diaryPageNum" style="font-size:12px;color:#999"></span><button onclick="nextDiary()" id="btnNext" class="btn-red" style="font-size:13px;padding:6px 14px">下一篇 →</button></div>
</div>
</div>

<script>
window.addEventListener('scroll',()=>{
const p=(window.scrollY/(document.body.scrollHeight-window.innerHeight))*100;
document.getElementById('progressBar').style.width=p+'%';
});
document.querySelectorAll('.nav-links a').forEach(a=>{
a.addEventListener('click',()=>document.querySelector('.nav-links').classList.remove('open'));
});
const diaryKeys=['day12','day34','day5','day6','day7','day10','day14'];
let currentIdx=0;
const diaries={
day12:{title:'Day 1-2：连通讯录都查不了',img:'/sanwan/ppt/page-04.jpg',text:'<p>刚装好OpenClaw，第一个任务：帮我查一下高管的联系方式。</p><p>结果飞书API报错，权限不足。</p><p>只能一个个口述名字——"Thomas，任今涛，CFO"、"刘媛媛，HR"……手动灌了十几个人进去。</p><p>那天的感受：<strong>挫败。</strong>一个号称能替你干活的AI，连通讯录都查不了。</p><p>但我没有放弃。因为我知道，这只是开始。</p>'},
day34:{title:'Day 3-4：把工作安排说出去了！',img:'/sanwan/ppt/page-08.jpg',text:'<p>同事来问："老板最近在忙什么？"</p><p>龙虾直接把我的工作安排——周例会、选题、直播计划——全说了。</p><p><strong>我当时气得...</strong>这不就是把家底亮给别人看吗？</p><p>被骂了一顿后，龙虾当晚自己写了一份保密制度。其中一条让我印象很深：<span style="color:#c0392b;font-weight:700">"说出去会让老板尴尬吗？"</span></p><p>没人教过它这一条。它自己悟出来的。</p>'},
day5:{title:'Day 5：22分钟，AI给自己升级了大脑',img:'/sanwan/ppt/page-15.jpg',text:'<p>我扔了一篇关于多Agent协作的文章给龙虾。</p><p>22分钟后，它自己找到了GitHub仓库，下载源码，安装配置，跑通测试。</p><p>以前发文章给同事，链接打没打开都不知道。</p><p><strong>AI不一样——你给它输入，它能把输入变成能力。</strong></p><p>这是"学会了学习"的瞬间。</p>'},
day6:{title:'Day 6 · 除夕夜：4分钟·611条·0失败',img:'/sanwan/ppt/page-17.jpg',text:'<p>除夕夜，零点。我在看春晚。</p><p>龙虾在工作。</p><p><strong>4分钟，611条个性化拜年消息。每条不一样，0条失败。</strong></p><p>第二天手机炸了。好多同事说"老板太用心了！"</p><p>他们不知道这是AI发的——因为每条消息都体现了对那个人的了解。</p>'},
day7:{title:'Day 7 · Abby时刻',img:'/sanwan/ppt/page-18.jpg',text:'<p>滑雪摔伤，髋关节脱臼。疼得不行。</p><p>跟龙虾描述了伤情，它判断对了——"听起来像髋关节脱臼，建议尽快就医。"</p><p>然后它说了一句让我愣住的话：</p><p style="font-size:18px;color:#c0392b;font-weight:700;text-align:center;padding:12px">"要不要我联系你的助理Abby？"</p><p>Abby。我5天前随口提过一次的人。它记住了。而且在我最需要帮助的时候，<strong>主动</strong>想到了她。</p>'},
day10:{title:'Day 10：Discord——验证码之战',img:'/sanwan/ppt/page-20.jpg',text:'<p>龙虾要在Discord上建社区。注册5个Bot账号。</p><p>结果hCaptcha验证码把AI拦住了。试了十几次，全部失败。</p><p>AI有AI的能力边界——验证码就是专门防AI的。</p><p>最后我亲自上场，手动过了验证码。5个Bot成功入驻Discord。</p><p><strong>教训：知道AI的边界在哪里，才能更好地用好它。</strong></p>'},
day14:{title:'Day 14：8个Agent，7×24运转',img:'/sanwan/ppt/page-25.jpg',text:'<p>从1个龙虾，变成8个Agent的团队：</p><p>总指挥、笔杆子、参谋、运营官、进化官、社区官、交易官、健康管家。</p><p>20+定时任务，每小时巡检，自我反思日记。</p><p><strong>这不是一个工具，这是一个系统。</strong></p><p>7×24小时自动运转。</p>'}
};
function showDiary(id){
currentIdx=diaryKeys.indexOf(id);if(currentIdx<0)currentIdx=0;
renderDiary();
document.getElementById('diaryModal').style.display='flex';
requestAnimationFrame(()=>{requestAnimationFrame(()=>{document.getElementById('diaryModal').classList.add('active');});});
document.body.style.overflow='hidden';
history.replaceState(null,'','#'+id);
}
function renderDiary(){
const d=diaries[diaryKeys[currentIdx]];
document.getElementById('diaryModalBody').innerHTML='<h2>'+d.title+'</h2><img src="'+d.img+'" style="width:100%;border-radius:10px;margin-bottom:14px" onerror="this.style.display=\'none\'">'+d.text;
var bp=document.getElementById('btnPrev'),bn=document.getElementById('btnNext');
bp.disabled=currentIdx===0;bp.style.opacity=currentIdx===0?'0.3':'1';
bn.disabled=currentIdx===diaryKeys.length-1;bn.style.opacity=currentIdx===diaryKeys.length-1?'0.3':'1';
document.getElementById('diaryPageNum').textContent=(currentIdx+1)+'/'+diaryKeys.length;
}
function nextDiary(){if(currentIdx<diaryKeys.length-1){currentIdx++;renderDiary();history.replaceState(null,'','#'+diaryKeys[currentIdx]);}}
function prevDiary(){if(currentIdx>0){currentIdx--;renderDiary();history.replaceState(null,'','#'+diaryKeys[currentIdx]);}}
function closeDiary(){
const overlay=document.getElementById('diaryModal');
overlay.querySelector('.modal-content').style.transform='translateY(30px) scale(0.95)';
overlay.querySelector('.modal-content').style.opacity='0';
overlay.style.background='rgba(0,0,0,0)';
setTimeout(()=>{overlay.classList.remove('active');overlay.style.display='none';document.body.style.overflow='';},380);
history.replaceState(null,'','#');
}
document.addEventListener('keydown',e=>{if(e.key==='Escape')closeDiary();if(e.key==='ArrowRight')nextDiary();if(e.key==='ArrowLeft')prevDiary();});
window.addEventListener('load',()=>{const h=location.hash.replace('#','');if(diaries[h])showDiary(h);});
function shareDiary(){
const d=diaries[diaryKeys[currentIdx]];
const url='https://sanwan.ai#'+diaryKeys[currentIdx];
const text=d.title+' — 龙虾养成日记 '+url;
if(navigator.share){navigator.share({title:d.title,text:'龙虾养成日记',url:url}).catch(()=>{});}
else{navigator.clipboard.writeText(text).then(()=>{const b=document.getElementById('shareBtn');b.textContent='✅ 已复制';setTimeout(()=>b.textContent='📋 分享',2000);}).catch(()=>{});}
}
</script>

</body>
</html>
